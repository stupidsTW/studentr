---
import Layout from '../layouts/Layout.astro';
---

<Layout title="老師回應紀錄">
  <!-- 密碼保護閘門 -->
  <div id="passwordGate" class="card" style="max-width: 420px; margin: 0 auto 1.5rem; text-align: center;">
    <h2 style="border-bottom: none; margin-bottom: 0.5rem;">🔒 老師專用區域</h2>
    <p style="color: #718096; font-size: 0.95rem;">請輸入密碼以查看與編輯回應紀錄</p>
    <div style="display: flex; gap: 0.5rem; justify-content: center; align-items: center; margin-top: 1rem;">
      <input type="password" id="teacherPassword" placeholder="輸入老師密碼" style="max-width: 220px;" />
      <button type="button" id="unlockBtn" style="margin-top: 0; padding: 0.6rem 1.2rem;">解鎖</button>
    </div>
    <div id="pwError" style="color: #e94560; font-size: 0.85rem; margin-top: 0.5rem; display: none;"></div>
  </div>

  <div id="protectedContent" style="display: none;">
    <div class="card">
      <h2>👨‍🏫 老師回應紀錄</h2>
      <form id="responseForm">
      <label for="student_filter">先選擇研究生</label>
      <select id="student_filter" required>
        <option value="">— 請選擇學生 —</option>
      </select>

      <label for="progress_id">選擇要回應的進度（該學生最近 5 筆）</label>
      <select id="progress_id" required>
        <option value="">— 請先選擇學生 —</option>
      </select>

      <div id="progressDetail" style="background:#f7fafc; border-radius:8px; padding:1rem; margin-top:0.5rem; display:none;">
        <p><strong>學生：</strong> <span id="detail_name"></span></p>
        <p><strong>日期：</strong> <span id="detail_date"></span></p>
        <p><strong>成果：</strong> <span id="detail_summary"></span></p>
        <p><strong>問題：</strong> <span id="detail_problem"></span></p>
        <p><strong>字數：</strong> <span id="detail_words"></span></p>
      </div>

      <label for="response_date">回應日期（自動填入）</label>
      <input type="date" id="response_date" readonly />

      <label for="response_content">回應內容</label>
      <textarea id="response_content" placeholder="請輸入老師的回應內容..." required></textarea>

      <button type="submit">📤 提交回應</button>
      <div id="message"></div>
    </form>
  </div>

  <div class="card">
    <h2>📋 所有回應紀錄</h2>
    <div id="responseList">載入中...</div>
  </div>

  <script>
    const today = new Date().toISOString().split('T')[0];
    document.getElementById('response_date').value = today;

    let allProgressData = [];

    async function loadAllProgressForTeacher() {
      try {
        const res = await fetch('/api/progress');
        const data = await res.json();
        if (data && data.error) throw new Error(data.error);
        allProgressData = Array.isArray(data) ? data : [];
      } catch (e) {
        console.error('載入進度失敗:', e);
        allProgressData = [];
      }
    }

    function populateStudentSelector() {
      const sel = document.getElementById('student_filter');
      const uniqueStudents = [...new Set(allProgressData.map(p => p.student_name))].filter(Boolean).sort();

      sel.innerHTML = '<option value="">— 請選擇學生 —</option>' +
        uniqueStudents.map(s => `<option value="${s}">${s}</option>`).join('');
    }

    function loadRecentProgressForStudent(studentName) {
      const progressSel = document.getElementById('progress_id');
      const detailBox = document.getElementById('progressDetail');
      detailBox.style.display = 'none';

      if (!studentName) {
        progressSel.innerHTML = '<option value="">— 請先選擇學生 —</option>';
        return;
      }

      // 取該學生最近 5 筆（API 已依日期降序）
      const recent = allProgressData
        .filter(p => p.student_name === studentName)
        .slice(0, 5);

      if (recent.length === 0) {
        progressSel.innerHTML = '<option value="">該學生尚無進度紀錄</option>';
        return;
      }

      progressSel.innerHTML = '<option value="">— 選擇要回應的進度 —</option>' +
        recent.map(p => {
          const summary = p.current_summary || '';
          return `<option value="${p.id}">[${p.date}] ${summary.substring(0, 35)}${summary.length > 35 ? '...' : ''}</option>`;
        }).join('');
    }

    // 學生選擇時載入最近 5 筆
    document.getElementById('student_filter').addEventListener('change', (e) => {
      loadRecentProgressForStudent(e.target.value);
    });

    // 選擇進度時顯示詳細資訊
    document.getElementById('progress_id').addEventListener('change', async (e) => {
      const id = e.target.value;
      const detail = document.getElementById('progressDetail');
      if (!id) { detail.style.display = 'none'; return; }
      try {
        const res = await fetch(`/api/progress/${id}`);
        const data = await res.json();
        if (data && data.error) {
          throw new Error(data.error);
        }
        document.getElementById('detail_name').textContent = data.student_name || '';
        document.getElementById('detail_date').textContent = data.date || '';
        document.getElementById('detail_summary').textContent = data.current_summary || '';
        document.getElementById('detail_problem').textContent = `${data.problem_categories || '無'} — ${data.problem_summary || ''}`;
        document.getElementById('detail_words').textContent = data.word_count || '';
        detail.style.display = 'block';
      } catch(e) {
        detail.style.display = 'none';
        console.error('載入進度詳情失敗:', e.message);
      }
    });

    // 載入回應列表
    async function loadResponses() {
      const el = document.getElementById('responseList');
      try {
        const res = await fetch('/api/response');
        let data = await res.json();
        if (data && data.error) {
          throw new Error(data.error);
        }
        const progressRes = await fetch('/api/progress');
        let progressData = await progressRes.json();
        if (progressData && progressData.error) {
          throw new Error(progressData.error);
        }
        if (!Array.isArray(data)) data = [];
        if (!Array.isArray(progressData)) progressData = [];
        const progressMap = {};
        progressData.forEach(p => { progressMap[p.id] = p; });

        if (!data.length) {
          el.innerHTML = '<p style="color:#718096;">尚無回應紀錄</p>';
          return;
        }
        el.innerHTML = `<table>
          <thead><tr><th>日期</th><th>對應學生</th><th>回應內容</th></tr></thead>
          <tbody>${data.slice(0,20).map(r => {
            const p = progressMap[r.progress_id];
            const student = p ? p.student_name : '（已刪除）';
            const content = r.response_content || '';
            return `<tr>
              <td>${r.response_date}</td>
              <td><strong>${student}</strong></td>
              <td>${content.substring(0, 40)}${content.length > 40 ? '...' : ''}</td>
            </tr>`;
          }).join('')}</tbody>
        </table>`;
      } catch(e) {
        el.innerHTML = `<p class="message error">無法載入回應資料：${e.message}</p>`;
      }
    }
    loadResponses();

    // 提交回應
    document.getElementById('responseForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button');
      btn.disabled = true;
      const msgEl = document.getElementById('message');

      const payload = {
        progress_id: document.getElementById('progress_id').value,
        response_date: document.getElementById('response_date').value,
        response_content: document.getElementById('response_content').value,
      };

      try {
        const res = await fetch('/api/response', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await res.json();
        if (res.ok) {
          msgEl.innerHTML = '<p class="message success">✅ 回應已成功提交！</p>';
          e.target.reset();
          document.getElementById('response_date').value = today;
          document.getElementById('progressDetail').style.display = 'none';
          loadResponses();
        } else {
          msgEl.innerHTML = `<p class="message error">❌ ${result.error}</p>`;
        }
      } catch(e) {
        msgEl.innerHTML = '<p class="message error">❌ 提交失敗</p>';
      }
      btn.disabled = false;
    });

    // 老師密碼保護
    const TEACHER_PW = import.meta.env.PUBLIC_TEACHER_PASSWORD || '';
    const gate = document.getElementById('passwordGate');
    const content = document.getElementById('protectedContent');
    const pwInput = document.getElementById('teacherPassword');
    const unlockBtn = document.getElementById('unlockBtn');
    const pwError = document.getElementById('pwError');

    async function unlock() {
      if (!TEACHER_PW) {
        pwError.textContent = '尚未設定 PUBLIC_TEACHER_PASSWORD，請聯絡管理員';
        pwError.style.display = 'block';
        return;
      }
      if (pwInput.value === TEACHER_PW) {
        gate.style.display = 'none';
        content.style.display = 'block';
        // 載入所有進度 + 學生清單
        await loadAllProgressForTeacher();
        populateStudentSelector();
        if (typeof loadResponses === 'function') loadResponses();
      } else {
        pwError.textContent = '密碼錯誤，請重試';
        pwError.style.display = 'block';
      }
    }

    unlockBtn.addEventListener('click', () => unlock());
    pwInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        unlock();
      }
    });

    // 預設 focus
    setTimeout(() => pwInput.focus(), 100);
  </script>
  </div> <!-- /protectedContent -->
</Layout>
