---
import Layout from '../layouts/Layout.astro';
---

<Layout title="研究進度儀錶板">
  <!-- 密碼保護閘門 -->
  <div id="passwordGate" class="card" style="max-width: 420px; margin: 0 auto 1.5rem; text-align: center;">
    <h2 style="border-bottom: none; margin-bottom: 0.5rem;">🔒 老師專用區域</h2>
    <p style="color: #718096; font-size: 0.95rem;">請輸入密碼以查看研究進度儀錶板</p>
    <div style="display: flex; gap: 0.5rem; justify-content: center; align-items: center; margin-top: 1rem;">
      <input type="password" id="teacherPassword" placeholder="輸入老師密碼" style="max-width: 220px;" />
      <button type="button" id="unlockBtn" style="margin-top: 0; padding: 0.6rem 1.2rem;">解鎖</button>
    </div>
    <div id="pwError" style="color: #e94560; font-size: 0.85rem; margin-top: 0.5rem; display: none;"></div>
  </div>

  <div id="protectedContent" style="display: none;">
    <div class="card">
      <h2>📊 研究進度儀錶板</h2>
      <p style="color:#718096; margin-bottom:1rem;">以研究生為單位，顯示最近5筆的進度與回應資訊彙整。</p>
      <div id="dashboardContent">載入中...</div>
    </div>

  <script>
    async function loadDashboard() {
      const el = document.getElementById('dashboardContent');
      try {
        const res = await fetch('/api/dashboard');
        const data = await res.json();
        if (data && data.error) {
          throw new Error(data.error);
        }
        if (!Array.isArray(data) || !data.length) {
          el.innerHTML = '<p style="color:#718096;">尚無資料</p>';
          return;
        }

        let html = '';
        for (const student of data) {
          const latest = student.items[0];
          html += `<div style="border:1px solid #e2e8f0; border-radius:12px; padding:1.2rem; margin-bottom:1.5rem; background:#fff;">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
              <h3 style="color:#1a1a2e; font-size:1.2rem;">🎓 ${student.student_name}</h3>
              <span style="font-size:0.85rem; color:#718096;">最近 ${student.items.length} 筆進度</span>
            </div>

            <!-- 字數變化 -->
            <div style="margin-top:0.8rem; padding:0.8rem; background:#f7fafc; border-radius:8px;">
              <strong>📈 字數變化：</strong>
              <span>${student.wordCounts.join(' → ')}</span>
              <span style="margin-left:0.5rem; font-weight:700; color:${student.wordChange >= 0 ? '#22543d' : '#822727'}">
                (${student.wordChange >= 0 ? '+' : ''}${student.wordChange})
              </span>
            </div>

            <!-- 問題分類統計 -->
            <div style="margin-top:0.8rem;">
              <strong>🏷️ 問題分類統計：</strong>
              <div style="margin-top:0.3rem;">
                ${Object.entries(student.categoryCount).map(([cat, count]) =>
                  count > 0 ? `<span class="badge" style="background:#e94560; color:#fff;">${cat} (${count})</span>` : ''
                ).join('')}
                ${Object.keys(student.categoryCount).length === 0 ? '<span style="color:#a0aec0; font-size:0.85rem;">無分類資料</span>' : ''}
              </div>
            </div>

            <!-- 成果概述列表 -->
            <div style="margin-top:0.8rem;">
              <strong>📌 成果概述：</strong>
              <ul style="margin-top:0.3rem; padding-left:1.2rem; font-size:0.9rem;">
                ${student.items.map(item => `<li style="margin-bottom:0.3rem;"><strong>${item.date}</strong>：${item.current_summary}</li>`).join('')}
              </ul>
            </div>

            <!-- 問題概述列表 -->
            <div style="margin-top:0.8rem;">
              <strong>⚠️ 問題概述：</strong>
              <ul style="margin-top:0.3rem; padding-left:1.2rem; font-size:0.9rem;">
                ${student.items.map(item => `<li style="margin-bottom:0.3rem;"><strong>${item.date}</strong>：${item.problem_summary}</li>`).join('')}
              </ul>
            </div>

            <!-- 回應紀錄 -->
            <div style="margin-top:0.8rem; padding:0.8rem; background:#fefcf0; border-radius:8px; border-left:3px solid #e94560;">
              <strong>💬 回應紀錄：</strong>
              ${student.items.some(item => item.responses && item.responses.length > 0)
                ? student.items.map(item => {
                    if (!item.responses || item.responses.length === 0) return '';
                    return item.responses.map(r =>
                      `<div style="margin-top:0.3rem; font-size:0.85rem;">
                        <span style="color:#718096;">${r.response_date}</span>：${r.response_content}
                      </div>`
                    ).join('');
                  }).join('')
                : '<div style="color:#a0aec0; font-size:0.85rem; margin-top:0.3rem;">尚無老師回應</div>'
              }
            </div>

            <details style="margin-top:0.8rem;">
              <summary style="cursor:pointer; color:#e94560; font-weight:600; font-size:0.85rem;">查看原始進度資料</summary>
              <table style="margin-top:0.5rem; font-size:0.8rem;">
                <thead><tr><th>ID</th><th>日期</th><th>字數</th><th>分類</th></tr></thead>
                <tbody>${student.items.map(item => `<tr>
                  <td>${item.id}</td>
                  <td>${item.date}</td>
                  <td>${item.word_count}</td>
                  <td>${item.problem_categories || '-'}</td>
                </tr>`).join('')}</tbody>
              </table>
            </details>
          </div>`;
        }
        el.innerHTML = html;
      } catch(e) {
        el.innerHTML = `<p class="message error">無法載入儀錶板資料：${e.message}</p>`;
      }
    }
    loadDashboard();

    // 老師密碼保護
    const TEACHER_PW = import.meta.env.PUBLIC_TEACHER_PASSWORD || '';
    const gate = document.getElementById('passwordGate');
    const content = document.getElementById('protectedContent');
    const pwInput = document.getElementById('teacherPassword');
    const unlockBtn = document.getElementById('unlockBtn');
    const pwError = document.getElementById('pwError');

    function unlock() {
      if (!TEACHER_PW) {
        pwError.textContent = '尚未設定 PUBLIC_TEACHER_PASSWORD，請聯絡管理員';
        pwError.style.display = 'block';
        return;
      }
      if (pwInput.value === TEACHER_PW) {
        gate.style.display = 'none';
        content.style.display = 'block';
        if (typeof loadDashboard === 'function') loadDashboard();
      } else {
        pwError.textContent = '密碼錯誤，請重試';
        pwError.style.display = 'block';
      }
    }

    unlockBtn.addEventListener('click', unlock);
    pwInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        unlock();
      }
    });

    setTimeout(() => pwInput.focus(), 100);
  </script>
  </div> <!-- /protectedContent -->
</Layout>
